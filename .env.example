# Vidway environment configuration.
#
# Copy to `.env` and edit as needed. `.env` is gitignored and dockerignored,
# so secrets won't leak into the image or the repo.
#
# docker compose reads this file automatically for variable substitution
# in docker-compose.yml — no extra flags needed.


# ----------------------------------------------------------------------
# Local development (pnpm -r --parallel dev)
# ----------------------------------------------------------------------

# API server port
PORT=8787

# Path to SQLite database file (relative to api/ working dir)
DATABASE_PATH=./data/vidway.db

# CORS — origins allowed to call the API. Comma-separated. The dev
# default points at the Vite dev server.
CORS_ORIGIN=http://localhost:5173


# ----------------------------------------------------------------------
# Docker Compose (docker compose up --build)
# ----------------------------------------------------------------------

# The URL the browser uses to reach the API. Baked into the web bundle
# at build time (Vite resolves it from import.meta.env). Must be the
# host-exposed URL, NOT the docker-internal hostname — the browser has
# no idea what "api" is.
VITE_VIDWAY_API_URL=http://localhost:8787

# The URL the browser uses to load the web app. The API container uses
# this as its CORS_ORIGIN, since the request from the browser comes
# from this origin. Override when deploying behind a real domain.
WEB_PUBLIC_ORIGIN=http://localhost:8080

# Host ports for the two services. Override if 8080 / 8787 are already
# taken. Note: if you change these, also update the URLs above to match.
WEB_PORT=8080
API_PORT=8787
